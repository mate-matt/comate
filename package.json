{
  "name": "codex-mate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "CODEX_MATE_DEV_API=1 NODE_OPTIONS=--no-warnings tsx watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1 --port 4388",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "NODE_OPTIONS=--no-warnings node dist-server/server/index.js",
    "test": "NODE_OPTIONS=--no-warnings tsx tests/run-unit-tests.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
